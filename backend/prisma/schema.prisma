// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient {
  id          String   @id @default(uuid())
  name        String
  dob         DateTime
  gender      String
  bloodGroup  String?
  phone       String
  email       String?  @unique
  password    String?
  allergies   String?
  createdAt   DateTime @default(now())

  appointments Appointment[]
  emrRecords   EmrRecord[]
  invoices     BillingInvoice[]
  notifications Notification[]
  waitlists    Waitlist[]
  reviews      Review[]
}

model Doctor {
  id                 String   @id @default(uuid())
  name               String
  email              String?  @unique
  password           String?
  specialization     String
  departmentId       String
  experienceYears    Int      @default(0)
  about              String?  @db.Text
  consultationFee    Float    @default(0.0)
  avgConsultationTime Int      @default(600) // in seconds, default 10 mins
  isAvailable        Boolean  @default(true)

  appointments Appointment[]
  queueTokens  QueueToken[]
  emrRecords   EmrRecord[]
  schedules    DoctorSchedule[]
  waitlists    Waitlist[]
  reviews      Review[]
}

model Appointment {
  id               String    @id @default(uuid())
  patientId        String
  doctorId         String
  slotTime         DateTime
  tokenNumber      Int
  status           String    // e.g. PENDING, CONFIRMED, CANCELLED, LATE_CANCEL, NO_SHOW, COMPLETED
  bookingChannel   String    // APP, DESK, TELEMEDICINE, WHATSAPP, WEB
  consultationMode String    @default("IN_PERSON") // IN_PERSON, VIDEO
  paymentStatus    String    @default("PENDING") // PENDING, PREPAID, PAY_AT_CLINIC
  softLockUntil    DateTime?
  cancellationCode String?

  patient Patient @relation(fields: [patientId], references: [id])
  doctor  Doctor  @relation(fields: [doctorId], references: [id])

  queueToken QueueToken?
  invoices   BillingInvoice[]
  review     Review?
}

model QueueToken {
  id            String   @id @default(uuid())
  appointmentId String   @unique
  doctorId      String
  status        String   // WAITING, CALLED, IN_CONSULTATION, COMPLETED, SKIPPED
  queuePosition Int
  calledAt      DateTime?
  startTime     DateTime?
  endTime       DateTime?
  durationSec   Int?

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  doctor      Doctor      @relation(fields: [doctorId], references: [id])
}

model EmrRecord {
  id         String   @id @default(uuid())
  patientId  String
  doctorId   String
  visitDate  DateTime @default(now())
  soapNotes  String?
  icd10Code  String?
  vitalsJson Json?

  patient Patient @relation(fields: [patientId], references: [id])
  doctor  Doctor  @relation(fields: [doctorId], references: [id])

  prescriptions Prescription[]
  labOrders     LabOrder[]
}

model Prescription {
  id                     String   @id @default(uuid())
  emrRecordId            String
  medicinesJson          Json
  drugCheckPassed        Boolean  @default(false)
  dispatchedToPharmacy   Boolean  @default(false)
  createdAt              DateTime @default(now())

  emrRecord EmrRecord @relation(fields: [emrRecordId], references: [id])
}

model LabOrder {
  id           String   @id @default(uuid())
  emrRecordId  String
  testName     String
  urgency      String   // ROUTINE, URGENT, STAT
  status       String   // PENDING, COLLECTED, COMPLETED
  resultUrl    String?
  criticalFlag Boolean  @default(false)

  emrRecord EmrRecord @relation(fields: [emrRecordId], references: [id])
}

model BillingInvoice {
  id               String   @id @default(uuid())
  patientId        String
  appointmentId    String
  itemsJson        Json
  totalAmount      Float
  paymentStatus    String   // PENDING, PAID, FAILED
  insuranceClaimId String?

  patient     Patient     @relation(fields: [patientId], references: [id])
  appointment Appointment @relation(fields: [appointmentId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  patientId String
  type      String   // SMS, PUSH, EMAIL
  message   String
  channel   String
  sentAt    DateTime?
  readAt    DateTime?

  patient Patient @relation(fields: [patientId], references: [id])
}

model DoctorSchedule {
  id               String   @id @default(uuid())
  doctorId         String
  dayOfWeek        Int      // 0=Sun, 1=Mon, ..., 6=Sat
  startTime        String   // "09:00"
  endTime          String   // "13:00"
  slotDurationMins Int      @default(15)
  maxPatients      Int      @default(20)
  sessionType      String   // MORNING, EVENING
  modes            String   // IN_PERSON, VIDEO, BOTH
  isActive         Boolean  @default(true)

  doctor Doctor @relation(fields: [doctorId], references: [id])
}

model Waitlist {
  id            String   @id @default(uuid())
  patientId     String
  doctorId      String
  requestedDate DateTime // Target date the patient wants
  urgencyScore  Int      @default(0) // 10 if urgent, +loyalty points
  status        String   // WAITING, NOTIFIED, ACCEPTED, EXPIRED, CANCELLED
  notifiedAt    DateTime?
  createdAt     DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id])
  doctor  Doctor  @relation(fields: [doctorId], references: [id])
}

model Review {
  id            String   @id @default(uuid())
  patientId     String
  doctorId      String
  appointmentId String   @unique
  rating        Float    // 1.0 to 5.0
  waitTime      Int      // 1-5 score
  behaviour     Int      // 1-5 score
  treatment     Int      // 1-5 score
  recommend     Boolean
  comment       String?  @db.Text
  createdAt     DateTime @default(now())

  patient     Patient     @relation(fields: [patientId], references: [id])
  doctor      Doctor      @relation(fields: [doctorId], references: [id])
  appointment Appointment @relation(fields: [appointmentId], references: [id])
}

model Staff {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
  role     String // RECEPTIONIST, PHARMACIST, LAB_TECH, ADMIN
}
